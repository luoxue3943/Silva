# Git 忽略规则参考 / Reference for Git ignore rules:
# https://help.github.com/articles/ignoring-files/

# 依赖目录 / Dependency directories
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 测试产物 / Test artifacts
/coverage

# Next.js 构建产物 / Next.js build artifacts
/.next/
/out/

# 生产构建目录 / Production build directory
/build

# 杂项系统文件 / Miscellaneous system files
.DS_Store
*.pem

# 调试日志 / Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 环境变量文件（需要时可选择提交）/ Environment files (can opt in to committing when needed)
.env*

# Vercel 本地产物 / Vercel local artifacts
.vercel

# TypeScript 编译缓存 / TypeScript build cache
*.tsbuildinfo
next-env.d.ts
